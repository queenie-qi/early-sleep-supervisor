{
  "name": "early-sleep-supervisor",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev:client": "cd client && npx vite",
    "dev:server": "cd server && npx tsx watch index.ts",
    "dev": "npx concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "build": "cd client && npx tsc -b && npx vite build",
    "start": "cd server && npx tsx index.ts"
  },
  "dependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/multer": "^1.4.12",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "better-sqlite3": "^11.7.0",
    "concurrently": "^8.2.2",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^4.21.0",
    "multer": "^1.4.5-lts.1",
    "nanoid": "^5.0.9",
    "postcss": "^8.4.49",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0",
    "tailwindcss": "^3.4.15",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vite": "^6.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
